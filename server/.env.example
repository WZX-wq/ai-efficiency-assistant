# Server Configuration
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/ai-efficiency-assistant

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-here-min-32-characters
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-here-min-32-characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# AI API Configuration
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_URL=https://api.deepseek.com/v1

# Image Generation API
IMAGE_API_KEY=your-image-api-key
IMAGE_API_URL=https://api.baishan.com/v1/images

# Voice API Configuration
VOICE_API_KEY=your-voice-api-key
VOICE_API_URL=https://api.baishan.com/v1/voice

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE=104857600
ALLOWED_FILE_TYPES=image/*,application/pdf,text/*,video/*,audio/*

# Cloud Storage (Optional - for production)
# AWS_S3_BUCKET=your-bucket
# AWS_S3_REGION=your-region
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret

# System Monitor Configuration
MONITOR_INTERVAL=5000
ALERT_RETENTION_DAYS=30

# Database Connections (for Database Manager feature)
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=password

# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=password

# Email Configuration (for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
