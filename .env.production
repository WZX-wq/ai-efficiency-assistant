# ============================================
# AI效率助手 - 生产环境配置模板
# 复制此文件为 .env.production 并填写实际值
# ============================================

# 服务器配置
NODE_ENV=production
PORT=3001

# MongoDB 数据库连接
# 格式: mongodb://用户名:密码@主机:端口/数据库名
MONGODB_URI=mongodb://mongo:27017/ai-efficiency-assistant

# JWT 密钥（请使用随机生成的强密码，至少32位）
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# JWT 过期时间（默认7天）
JWT_EXPIRES_IN=7d

# DeepSeek API 配置
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 图片生成 API 配置（可选）
IMAGE_GEN_API_KEY=your-image-gen-api-key
IMAGE_GEN_BASE_URL=https://api.example.com

# 文件上传配置
# 最大文件大小（单位: MB）
MAX_FILE_SIZE=100
# 上传文件存储路径
UPLOAD_DIR=./uploads

# 跨域配置（生产环境建议限制具体域名）
CORS_ORIGIN=https://your-domain.com

# 日志级别: error | warn | info | debug
LOG_LEVEL=info

# 速率限制配置
# API 请求窗口时间（单位: 分钟）
RATE_LIMIT_WINDOW=15
# 窗口期内最大请求数
RATE_LIMIT_MAX=100

# 管理员账号（首次启动时自动创建）
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=change-this-password-immediately

# 域名配置（用于生成正确的回调URL等）
DOMAIN=https://your-domain.com
